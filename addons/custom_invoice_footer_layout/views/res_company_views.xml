<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_company_form_inherit_invoice_footer_columns" model="ir.ui.view">
        <field name="name">res.company.form.invoice.footer.columns</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Invoice Footer">
                    <group>
                        <group>
                            <field name="invoice_footer_col_1" placeholder="Left column text"/>
                            <field name="invoice_footer_col_2" placeholder="Middle column text"/>
                            <field name="invoice_footer_col_3" placeholder="Right column text"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>