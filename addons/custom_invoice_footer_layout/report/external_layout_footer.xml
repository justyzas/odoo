<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <template id="custom_external_layout_standard_footer"
              inherit_id="web.external_layout_standard">

        <!-- Remove company logo -->
        <xpath expr="//img[contains(@class, 'o_company_logo_small')]" position="replace"/>

        <!-- Remove seller address / company details block -->
        <xpath expr="//div[@name='company_address']" position="replace"/>

        <!-- Remove customer address block -->
        <xpath expr="//t[@t-call='web.address_layout']" position="replace"/>

        <!-- Remove document title heading -->
        <xpath expr="//h2[@t-out='layout_document_title']" position="replace"/>

        <xpath expr="//div[contains(@class, 'o_footer')]" position="replace">
            <div class="o_footer o_standard_footer o_company_#{company.id}_layout">
                <style>
                    .invoice-custom-footer {
                        display: flex;
                        justify-content: space-between;
                        width: 100%;
                    }
                    .invoice-custom-footer .col {
                        flex: 1;
                        vertical-align: top;
                    }
                    .invoice-custom-footer .col:nth-child(2) {
                        text-align: center;
                    }
                    .invoice-custom-footer .col:last-child {
                        text-align: right;
                    }
                </style>

                <!-- Apply custom footer only on invoice/account.move reports -->
                <t t-if="doc_model == 'account.move'">
                    <div class="invoice-custom-footer">
                        <div class="col" t-if="company.invoice_footer_col_1"
                             t-esc="company.invoice_footer_col_1"/>
                        <div class="col" t-if="company.invoice_footer_col_2"
                             t-esc="company.invoice_footer_col_2"/>
                        <div class="col" t-if="company.invoice_footer_col_3"
                             t-esc="company.invoice_footer_col_3"/>
                    </div>
                </t>

                <!-- Keep a simple fallback for non-invoice reports -->
                <t t-else="">
                    <div class="text-center" style="font-size: 10px; color: #666;">
                        <span t-if="company.phone" t-esc="company.phone"/>
                        <t t-if="company.phone and company.email"> | </t>
                        <span t-if="company.email" t-esc="company.email"/>
                        <t t-if="(company.phone or company.email) and company.website"> | </t>
                        <span t-if="company.website" t-esc="company.website"/>
                    </div>
                </t>
            </div>
        </xpath>

    </template>

</odoo>